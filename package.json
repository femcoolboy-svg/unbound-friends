{
  "name": "unbound-friends",
  "version": "2.0.0",
  "description": "Premium chat & calls with admin panel",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "docker:build": "docker build -t unbound-friends .",
    "docker:run": "docker run -p 3000:3000 -v $(pwd)/data.json:/app/data.json unbound-friends"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.6.1",
    "cookie-parser": "^1.4.6"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
